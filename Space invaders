import pygame
pygame.init()
x:400
y:300
mov=10
teladojogo=pygame.display.set_mode((800,600))
pygame.display.set_caption("Space atack")

jogo=true
while jogo:
	for event in pygame.event.get():
		if event.type == pygame.QUIT:
			jogo=false
		controles= pygame.key.get_pressed()
		if controles[pygame.k_UP]:
			y=y-mov
		if controles[pygame.k_DOWN]:
			y=y+mov
